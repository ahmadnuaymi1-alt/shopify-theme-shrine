{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-icon-grid-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
  }

  .ai-icon-grid__container-{{ ai_gen_id }} {
    padding: {{ block.settings.padding_top }}px {{ block.settings.padding_horizontal }}px {{ block.settings.padding_bottom }}px;
    background-color: {{ block.settings.background_color }};
    {% if block.settings.gradient_background != blank %}
      background-image: {{ block.settings.gradient_background }};
    {% endif %}
  }

  .ai-icon-grid__section-id-{{ ai_gen_id }} {
    font-size: 12px;
    color: {{ block.settings.text_color }};
    opacity: 0.6;
    margin-bottom: 8px;
    font-family: {{ block.settings.body_font.family }}, {{ block.settings.body_font.fallback_families }};
    font-weight: {{ block.settings.body_font.weight }};
  }

  .ai-icon-grid__heading-{{ ai_gen_id }} {
    margin: 0 0 {{ block.settings.heading_spacing }}px;
    color: {{ block.settings.text_color }};
    font-size: {{ block.settings.heading_size }}px;
    text-align: {{ block.settings.text_alignment }};
    font-family: {{ block.settings.heading_font.family }}, {{ block.settings.heading_font.fallback_families }};
    font-weight: {{ block.settings.heading_font.weight }};
    line-height: 1.3;
  }

  .ai-icon-grid__heading-{{ ai_gen_id }} strong {
    color: {{ block.settings.heading_highlight_color }};
  }

  .ai-icon-grid__text-{{ ai_gen_id }} {
    margin: 0 0 {{ block.settings.text_spacing }}px;
    color: {{ block.settings.text_color }};
    text-align: {{ block.settings.text_alignment }};
    font-family: {{ block.settings.body_font.family }}, {{ block.settings.body_font.fallback_families }};
    font-weight: {{ block.settings.body_font.weight }};
    line-height: 1.6;
  }

  .ai-icon-grid__grid-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat({{ block.settings.columns_desktop }}, 1fr);
    gap: {{ block.settings.grid_gap }}px;
    margin-top: {{ block.settings.grid_top_spacing }}px;
  }

  .ai-icon-grid__card-{{ ai_gen_id }} {
    background-color: {{ block.settings.card_background_color }};
    {% if block.settings.card_gradient_background != blank %}
      background-image: {{ block.settings.card_gradient_background }};
    {% endif %}
    border-radius: {{ block.settings.card_border_radius }}px;
    padding: {{ block.settings.card_padding }}px;
    text-align: {{ block.settings.text_alignment }};
    display: flex;
    {% if block.settings.icon_layout == 'horizontal' %}
      flex-direction: row;
      align-items: center;
      gap: {{ block.settings.icon_text_gap }}px;
    {% else %}
      flex-direction: column;
      align-items: {{ block.settings.text_alignment }};
      gap: {{ block.settings.icon_text_gap }}px;
    {% endif %}
  }

  .ai-icon-grid__icon-wrapper-{{ ai_gen_id }} {
    flex-shrink: 0;
    {% if block.settings.icon_layout == 'vertical' %}
      width: 100%;
      display: flex;
      justify-content: {{ block.settings.text_alignment }};
    {% endif %}
  }

  .ai-icon-grid__icon-{{ ai_gen_id }} {
    width: {{ block.settings.icon_size }}px;
    height: {{ block.settings.icon_size }}px;
    color: {{ block.settings.icon_color }};
    display: block;
  }

  .ai-icon-grid__card-content-{{ ai_gen_id }} {
    flex-grow: 1;
  }

  .ai-icon-grid__card-title-{{ ai_gen_id }} {
    margin: 0 0 8px;
    color: {{ block.settings.card_text_color }};
    font-size: 16px;
    font-family: {{ block.settings.heading_font.family }}, {{ block.settings.heading_font.fallback_families }};
    font-weight: {{ block.settings.heading_font.weight }};
  }

  .ai-icon-grid__card-text-{{ ai_gen_id }} {
    margin: 0;
    color: {{ block.settings.card_text_color }};
    font-size: 14px;
    line-height: 1.5;
    font-family: {{ block.settings.body_font.family }}, {{ block.settings.body_font.fallback_families }};
    font-weight: {{ block.settings.body_font.weight }};
  }

  @media screen and (max-width: 749px) {
    .ai-icon-grid__grid-{{ ai_gen_id }} {
      grid-template-columns: repeat({{ block.settings.columns_mobile }}, 1fr);
    }

    .ai-icon-grid__icon-{{ ai_gen_id }} {
      width: calc({{ block.settings.icon_size }}px * 0.8);
      height: calc({{ block.settings.icon_size }}px * 0.8);
    }
  }
{% endstyle %}

<icon-grid-{{ ai_gen_id }}
  class="ai-icon-grid-{{ ai_gen_id }}"
  {{ block.shopify_attributes }}
>
  <div class="ai-icon-grid__container-{{ ai_gen_id }}">
    {% if block.settings.section_id != blank %}
      <div class="ai-icon-grid__section-id-{{ ai_gen_id }}" id="{{ block.settings.section_id }}">
        ID: {{ block.settings.section_id }}
      </div>
    {% endif %}

    {% if block.settings.heading != blank %}
      <h2 class="ai-icon-grid__heading-{{ ai_gen_id }}">
        {{ block.settings.heading }}
      </h2>
    {% endif %}

    {% if block.settings.text != blank %}
      <div class="ai-icon-grid__text-{{ ai_gen_id }}">
        {{ block.settings.text }}
      </div>
    {% endif %}

    <div class="ai-icon-grid__grid-{{ ai_gen_id }}">
      {% for i in (1..12) %}
        {% liquid
          assign icon_key = 'icon_' | append: i
          assign title_key = 'title_' | append: i
          assign text_key = 'text_' | append: i
          
          assign icon = block.settings[icon_key]
          assign title = block.settings[title_key]
          assign text = block.settings[text_key]
        %}

        {% if icon != blank or title != blank or text != blank %}
          <div class="ai-icon-grid__card-{{ ai_gen_id }}">
            {% if icon != blank %}
              <div class="ai-icon-grid__icon-wrapper-{{ ai_gen_id }}">
                <svg class="ai-icon-grid__icon-{{ ai_gen_id }}" fill="currentColor" viewBox="0 0 24 24">
                  {% case icon %}
                    {% when 'shipping' %}
                      <path d="M18 18.5a1.5 1.5 0 0 1-1 1.415V21a1 1 0 1 1-2 0v-1.085a1.5 1.5 0 0 1 0-2.83V16a1 1 0 1 1 2 0v1.085A1.5 1.5 0 0 1 18 18.5zM8.5 20a1.5 1.5 0 1 0 0-3 1.5 1.5 0 0 0 0 3zm11-11h-2V7a1 1 0 0 0-1-1h-11a1 1 0 0 0-1 1v10a1 1 0 0 0 1 1h.535a3.5 3.5 0 0 1 6.93 0h3.07a3.5 3.5 0 0 1 3.465-3h.5a1 1 0 0 0 1-1v-3a1 1 0 0 0-1-1zm-1 2v1h-1v-1h1z"/>
                    {% when 'returns' %}
                      <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z"/>
                    {% when 'support' %}
                      <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm1 15h-2v-2h2v2zm0-4h-2V7h2v6z"/>
                    {% when 'secure' %}
                      <path d="M12 1L3 5v6c0 5.55 3.84 10.74 9 12 5.16-1.26 9-6.45 9-12V5l-9-4zm0 10.99h7c-.53 4.12-3.28 7.79-7 8.94V12H5V6.3l7-3.11v8.8z"/>
                    {% when 'quality' %}
                      <path d="M12 17.27L18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z"/>
                    {% when 'warranty' %}
                      <path d="M12 1L3 5v6c0 5.55 3.84 10.74 9 12 5.16-1.26 9-6.45 9-12V5l-9-4zm-2 16l-4-4 1.41-1.41L10 14.17l6.59-6.59L18 9l-8 8z"/>
                    {% when 'eco' %}
                      <path d="M17 8C8 10 5.9 16.17 3.82 21.34l1.89.66.95-2.3c.48.17.98.3 1.34.3C19 20 22 3 22 3c-1 2-8 2.25-13 3.25S2 11.5 2 13.5s1.75 3.75 1.75 3.75C7 8 17 8 17 8z"/>
                    {% when 'gift' %}
                      <path d="M20 6h-2.18c.11-.31.18-.65.18-1a2.996 2.996 0 0 0-5.5-1.65l-.5.67-.5-.68C10.96 2.54 10.05 2 9 2 7.34 2 6 3.34 6 5c0 .35.07.69.18 1H4c-1.11 0-1.99.89-1.99 2L2 19c0 1.11.89 2 2 2h16c1.11 0 2-.89 2-2V8c0-1.11-.89-2-2-2zm-5-2c.55 0 1 .45 1 1s-.45 1-1 1-1-.45-1-1 .45-1 1-1zM9 4c.55 0 1 .45 1 1s-.45 1-1 1-1-.45-1-1 .45-1 1-1zm11 15H4v-2h16v2zm0-5H4V8h5.08L7 10.83 8.62 12 11 8.76l1-1.36 1 1.36L15.38 12 17 10.83 14.92 8H20v6z"/>
                    {% when 'payment' %}
                      <path d="M20 4H4c-1.11 0-1.99.89-1.99 2L2 18c0 1.11.89 2 2 2h16c1.11 0 2-.89 2-2V6c0-1.11-.89-2-2-2zm0 14H4v-6h16v6zm0-10H4V6h16v2z"/>
                    {% when 'clock' %}
                      <path d="M11.99 2C6.47 2 2 6.48 2 12s4.47 10 9.99 10C17.52 22 22 17.52 22 12S17.52 2 11.99 2zM12 20c-4.42 0-8-3.58-8-8s3.58-8 8-8 8 3.58 8 8-3.58 8-8 8zm.5-13H11v6l5.25 3.15.75-1.23-4.5-2.67z"/>
                    {% when 'star' %}
                      <path d="M12 17.27L18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z"/>
                    {% when 'heart' %}
                      <path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"/>
                  {% endcase %}
                </svg>
              </div>
            {% endif %}

            <div class="ai-icon-grid__card-content-{{ ai_gen_id }}">
              {% if title != blank %}
                <h3 class="ai-icon-grid__card-title-{{ ai_gen_id }}">{{ title }}</h3>
              {% endif %}
              {% if text != blank %}
                <p class="ai-icon-grid__card-text-{{ ai_gen_id }}">{{ text }}</p>
              {% endif %}
            </div>
          </div>
        {% endif %}
      {% endfor %}
    </div>
  </div>
</icon-grid-{{ ai_gen_id }}>

<script>
  (function() {
    class IconGrid{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
      }
    }

    customElements.define('icon-grid-{{ ai_gen_id }}', IconGrid{{ ai_gen_id }});
  })();
</script>

