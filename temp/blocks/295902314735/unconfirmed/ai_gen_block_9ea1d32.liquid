<script>
  (function() {
    const headingSizeMap{{ ai_gen_id }} = {
      'small': 24,
      'medium': 32,
      'large': 40
    };

    const iconSizeMap{{ ai_gen_id }} = {
      'small': 32,
      'medium': 48,
      'large': 64
    };

    document.addEventListener('shopify:block:select', function(event) {
      const block = event.target;
      if (block && block.classList.contains('ai-icon-grid-{{ ai_gen_id }}')) {
        const headingSizeOption = '{{ block.settings.heading_size_option }}';
        const iconSizeOption = '{{ block.settings.icon_size_option }}';
        
        const headingSize = headingSizeMap{{ ai_gen_id }}[headingSizeOption] || 32;
        const iconSize = iconSizeMap{{ ai_gen_id }}[iconSizeOption] || 48;
        
        const heading = block.querySelector('.ai-icon-grid__heading-{{ ai_gen_id }}');
        if (heading) {
          heading.style.fontSize = headingSize + 'px';
        }
        
        const icons = block.querySelectorAll('.ai-icon-grid__icon-{{ ai_gen_id }}');
        icons.forEach(function(icon) {
          icon.style.width = iconSize + 'px';
          icon.style.height = iconSize + 'px';
        });
      }
    });
  })();
</script>

<style>
  {% assign heading_size_option = block.settings.heading_size_option %}
  {% assign icon_size_option = block.settings.icon_size_option %}
  
  {% if heading_size_option == 'small' %}
    {% assign heading_size = 24 %}
  {% elsif heading_size_option == 'large' %}
    {% assign heading_size = 40 %}
  {% else %}
    {% assign heading_size = 32 %}
  {% endif %}
  
  {% if icon_size_option == 'small' %}
    {% assign icon_size = 32 %}
  {% elsif icon_size_option == 'large' %}
    {% assign icon_size = 64 %}
  {% else %}
    {% assign icon_size = 48 %}
  {% endif %}
  
  .ai-icon-grid__heading-{{ ai_gen_id }} {
    font-size: {{ heading_size }}px;
  }
  
  .ai-icon-grid__icon-{{ ai_gen_id }} {
    width: {{ icon_size }}px;
    height: {{ icon_size }}px;
  }
  
  @media screen and (max-width: 749px) {
    .ai-icon-grid__icon-{{ ai_gen_id }} {
      width: calc({{ icon_size }}px * 0.8);
      height: calc({{ icon_size }}px * 0.8);
    }
  }
</style>
