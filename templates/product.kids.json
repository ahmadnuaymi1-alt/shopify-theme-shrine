    "kids-faq": {
      "type": "collapsible-content",
      "blocks": {
        "kids-faq-1": {
          "type": "collapsible_row",
          "settings": {
            "heading": "What ages is this suitable for?",
            "row_content": "<p>Each product page includes a recommended age range. Our products are designed with specific developmental stages in mind, so you can find the perfect match for your child.</p>"
          }
        },
        "kids-faq-2": {
          "type": "collapsible_row",
          "settings": {
            "heading": "Are the materials safe for children?",
            "row_content": "<p>Absolutely. All our kids’ products are made from BPA-free, lead-free, and non-toxic materials. They meet or exceed all relevant safety standards including CPSIA and ASTM requirements.</p>"
          }
        },
        "kids-faq-3": {
          "type": "collapsible_row",
          "settings": {
            "heading": "How durable are these products?",
            "row_content": "<p>Our products are built to withstand the enthusiasm of active kids. We use high-quality, reinforced materials designed to hold up to daily play, drops, and everything in between.</p>"
          }
        },
        "kids-faq-4": {
          "type": "collapsible_row",
          "settings": {
            "heading": "What if my child doesn’t like it?",
            "row_content": "<p>We offer a 30-day satisfaction guarantee on all products. If your child isn’t happy, we’ll gladly provide a full refund or exchange. Your family’s happiness is our priority.</p>"
          }
        }
      },
