    "baby-faq": {
      "type": "collapsible-content",
      "blocks": {
        "baby-faq-1": {
          "type": "collapsible_row",
          "settings": {
            "heading": "Is this safe for newborns?",
            "icon": "check_box",
            "filled_icon": false,
            "row_content": "<p>Yes, all our baby products meet strict CPSC safety standards and are designed specifically for the most delicate little ones. Every item is tested for safety before it reaches your family.</p>",
            "page": ""
          }
        },
        "baby-faq-2": {
          "type": "collapsible_row",
          "settings": {
            "heading": "What materials are used?",
            "icon": "check_box",
            "filled_icon": false,
            "row_content": "<p>We use only premium, hypoallergenic fabrics that are gentle on sensitive baby skin. All materials are free from harmful chemicals, BPA, phthalates, and lead.</p>",
            "page": ""
          }
        },
        "baby-faq-3": {
          "type": "collapsible_row",
          "settings": {
            "heading": "How do I wash and care for this?",
            "icon": "check_box",
            "filled_icon": false,
            "row_content": "<p>Most of our baby products are machine washable on a gentle cycle. Use mild, baby-safe detergent and tumble dry on low. Check individual product pages for specific care instructions.</p>",
            "page": ""
          }
        },
        "baby-faq-4": {
          "type": "collapsible_row",
          "settings": {
            "heading": "Is this suitable as a gift?",
