      "type": "collapsible-content",
      "blocks": {
        "pet-faq-1": {
          "type": "collapsible_row",
          "settings": {
            "heading": "Is this safe for my pet?",
            "row_content": "<p>Yes! All our pet products are made from non-toxic, pet-safe materials. They’re rigorously tested to ensure they’re safe for chewing, playing, and everyday use.</p>"
          }
        },
        "pet-faq-2": {
          "type": "collapsible_row",
          "settings": {
            "heading": "What size should I get?",
            "row_content": "<p>Check the size guide on each product page for detailed measurements. If you’re unsure, our support team is happy to help you find the perfect fit for your furry friend.</p>"
          }
        },
        "pet-faq-3": {
          "type": "collapsible_row",
          "settings": {
            "heading": "How do I clean/maintain this?",
            "row_content": "<p>Most of our pet products are easy to clean — simply wipe down with a damp cloth or hand wash with mild soap. Check individual product pages for specific care instructions.</p>"
          }
        },
        "pet-faq-4": {
          "type": "collapsible_row",
          "settings": {
            "heading": "What if my pet doesn’t like it?",
            "row_content": "<p>We offer a 30-day happiness guarantee. If your pet isn’t a fan, simply contact us for a full refund or exchange. No questions asked!</p>"
          }
        }
